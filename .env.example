# Local backend binding
HOST=127.0.0.1
PORT=3001

# Backend auth
JWT_SECRET=replace-with-a-secure-secret

# Wallet / chain configuration
EVM_RPC_URL=https://ethereum.publicnode.com
DEFAULT_EVM_CHAIN_ID=1
WALLET_AUTH_MESSAGE_PREFIX=Sign this message to access Game Forge.

# WeChat Mini Program backend configuration
WECHAT_APP_ID=replace-with-wechat-mini-program-app-id
WECHAT_APP_SECRET=replace-with-wechat-mini-program-app-secret

# Frontend API target
VITE_GAME_FORGE_API_BASE_URL=http://127.0.0.1:3001
# Optional frontend signaling target. Leave empty locally to derive from the API target or Vite proxy.
VITE_GAME_FORGE_SIGNALING_BASE_URL=

# Local development runner
GAME_FORGE_OPEN_BROWSER=1
