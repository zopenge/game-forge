{
  "name": "game-forge",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.0.0",
  "scripts": {
    "build": "pnpm -r --if-present build",
    "start": "pnpm start:game-client",
    "start:admin-panel": "pnpm --filter @game-forge/admin-panel start",
    "start:backend": "pnpm --filter @game-forge/backend start",
    "start:backend:logged": "powershell -ExecutionPolicy Bypass -File ./scripts/start-backend-with-log.ps1",
    "start:game-client": "pnpm --filter @game-forge/game-client start",
    "start:game-client:logged": "powershell -ExecutionPolicy Bypass -File ./scripts/start-game-client-with-log.ps1",
    "dev:admin-panel": "pnpm --filter @game-forge/admin-panel dev",
    "dev:backend": "pnpm --filter @game-forge/backend dev",
    "dev:game-client": "pnpm --filter @game-forge/game-client dev",
    "dev:game-client:logged": "powershell -ExecutionPolicy Bypass -File ./scripts/dev-game-client-with-log.ps1",
    "lint": "eslint . --max-warnings 0",
    "lint:fix": "eslint . --fix --max-warnings 0",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit -p tsconfig.json"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@fastify/cors": "^10.0.2",
    "@fastify/jwt": "^9.1.0",
    "@types/node": "^22.10.2",
    "@types/three": "^0.184.0",
    "eslint": "^10.2.1",
    "fastify": "^5.2.1",
    "globals": "^17.5.0",
    "jsdom": "^25.0.1",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3",
    "typescript-eslint": "^8.59.1",
    "vite": "^5.4.11",
    "vitest": "^2.1.5"
  }
}
