{
  "name": "game-forge",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.0.0",
  "scripts": {
    "build": "pnpm -r --if-present build",
    "build:admin-panel": "pnpm --filter @game-forge/admin-panel build",
    "build:backend": "pnpm --filter @game-forge/backend build",
    "build:game-client": "pnpm --filter @game-forge/game-client build",
    "create:render-env": "node ./scripts/create-render-env.mjs",
    "deploy:build:admin-panel": "pnpm install --frozen-lockfile && pnpm build:admin-panel",
    "deploy:build:game-client": "pnpm install --frozen-lockfile && pnpm build:game-client",
    "deploy:cloudflare:edge": "wrangler deploy --config wrangler.jsonc",
    "deploy:start:backend": "pnpm --filter @game-forge/backend start",
    "dev": "node ./scripts/run-many.mjs",
    "start": "pnpm start:game-client",
    "start:admin-panel": "pnpm --filter @game-forge/admin-panel start",
    "start:backend": "pnpm --filter @game-forge/backend start",
    "start:backend:logged": "node ./scripts/run-with-log.mjs @game-forge/backend start .tmp-backend-start.log",
    "start:game-client": "pnpm --filter @game-forge/game-client start",
    "start:game-client:logged": "node ./scripts/run-with-log.mjs @game-forge/game-client start .tmp-game-client-start.log",
    "dev:admin-panel": "pnpm --filter @game-forge/admin-panel dev",
    "dev:backend": "pnpm --filter @game-forge/backend dev",
    "dev:cloudflare:edge": "wrangler dev --config wrangler.jsonc",
    "dev:game-client": "pnpm --filter @game-forge/game-client dev",
    "dev:game-client:logged": "node ./scripts/run-with-log.mjs @game-forge/game-client dev .tmp-game-client-dev.log",
    "lint": "eslint . --max-warnings 0",
    "lint:fix": "eslint . --fix --max-warnings 0",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit -p tsconfig.json"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260503.1",
    "@eslint/js": "^10.0.1",
    "@fastify/cors": "^11.2.0",
    "@fastify/jwt": "^10.0.0",
    "@types/node": "^25.6.0",
    "@types/three": "^0.184.0",
    "eslint": "^10.2.1",
    "fastify": "^5.8.5",
    "globals": "^17.5.0",
    "jsdom": "^29.1.1",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.1",
    "vite": "^8.0.10",
    "vitest": "^4.1.5",
    "wrangler": "^4.87.0"
  }
}
