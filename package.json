{
  "name": "game-forge",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.0.0",
  "scripts": {
    "build": "pnpm -r --if-present build",
    "dev:admin-panel": "pnpm --filter @game-forge/admin-panel dev",
    "dev:game-client": "pnpm --filter @game-forge/game-client dev",
    "lint": "eslint . --max-warnings 0",
    "lint:fix": "eslint . --fix --max-warnings 0",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit -p tsconfig.json"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^22.10.2",
    "@types/three": "^0.184.0",
    "eslint": "^10.2.1",
    "globals": "^17.5.0",
    "jsdom": "^25.0.1",
    "typescript": "^5.6.3",
    "typescript-eslint": "^8.59.1",
    "vite": "^5.4.11",
    "vitest": "^2.1.5"
  }
}
