{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2023", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "allowImportingTsExtensions": false,
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": true,
    "useDefineForClassFields": true,
    "isolatedModules": true,
    "verbatimModuleSyntax": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "paths": {
      "@game-forge/backend/*": ["./apps/backend/src/*"],
      "@game-forge/assets": ["./packages/assets/src/index.ts"],
      "@game-forge/device": ["./packages/device/src/index.ts"],
      "@game-forge/bee-shooter": ["./packages/games/bee-shooter/src/index.ts"],
      "@game-forge/falling-blocks": ["./packages/games/falling-blocks/src/index.ts"],
      "@game-forge/game-cartridge": ["./packages/game-cartridge/src/index.ts"],
      "@game-forge/graphics": ["./packages/graphics/src/index.ts"],
      "@game-forge/i18n": ["./packages/i18n/src/index.ts"],
      "@game-forge/identity": ["./packages/identity/src/index.ts"],
      "@game-forge/input": ["./packages/input/src/index.ts"],
      "@game-forge/platform": ["./packages/platform/src/index.ts"],
      "@game-forge/resources": ["./packages/resources/src/index.ts"],
      "@game-forge/runtime": ["./packages/runtime/src/index.ts"],
      "@game-forge/shared-resources": ["./packages/shared-resources/src/index.ts"],
      "@game-forge/wallet-core": ["./packages/wallet/core/src/index.ts"],
      "@game-forge/wallet-evm": ["./packages/wallet/evm/src/index.ts"]
    },
    "types": ["node"]
  }
}
